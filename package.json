{
  "name": "float-todo-app",
  "version": "1.0.0",
  "description": "悬浮于桌面和网页之上的每日待办清单",
  "main": "src/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --dev",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "release": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always"
  },
  "keywords": [],
  "author": "wugengyue",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wugengyue.float-todo",
    "productName": "FloatTodo",
    "copyright": "Copyright © 2025 wugengyue",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "src/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "FloatTodo",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FloatTodo"
    },
    "publish": {
      "provider": "github",
      "owner": "CarrieWU02",
      "repo": "float-todo-app"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
